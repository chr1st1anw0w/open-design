    "az_labels": {
      "enabled": false,
      "rule": "非雲多 AZ 場景，關閉 AZ 標，可改標 city code"
    }
  },
  "legend": {
    "enabled": true,
    "position": "bottom-right",
    "content": "router/防火牆/CPE/server glyph；MPLS 與網際網路雙上行樣式；IPsec+BGP 上雲；logical 為灰虛線",
    "style": "small panel, mono 10pt"
  },
  "constraints": {
    "must_keep": [
      "站點用虛線大框+ CIDR",
      "MPLS 與 internet 以不同線型/平行雙線區分",
      "加密跨域鏈路帶鎖或 'IPsec' 小字"
    ],
    "avoid": [
      "Cisco/華為 官方產品剪影",
      "未標註速率的廣域網粗線"
    ]
  }
