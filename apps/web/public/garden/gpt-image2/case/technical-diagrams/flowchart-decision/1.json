        "to": "D1"
      },
      {
        "from": "D1",
        "to": "P2",
        "label": "Yes"
      },
      {
        "from": "D1",
        "to": "P3",
        "label": "No"
      },
      {
        "from": "P2",
        "to": "E"
      },
      {
        "from": "P3",
        "to": "D2"
      },
      {
        "from": "D2",
        "to": "SP1",
        "label": "No"
      },
      {
        "from": "D2",
        "to": "P4",
        "label": "Yes"
      },
      {
        "from": "SP1",
        "to": "E"
      },
      {
        "from": "P4",
        "to": "D3"
      },
      {
        "from": "D3",
        "to": "P5",
        "label": "Yes"
      },
      {
        "from": "D3",
        "to": "E",
        "label": "No"
      },
      {
        "from": "P5",
        "to": "D4"
      },
      {
        "from": "D4",
        "to": "P6",
