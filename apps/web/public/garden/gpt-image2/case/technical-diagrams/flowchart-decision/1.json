    "edge_style": {
      "default": "slate 1.5px + 三角箭頭",
      "yes_branch": "emerald #34D399",
      "no_branch": "slate",
      "exception_branch": {
        "enabled": "true",
        "style": "dashed rose",
        "use_on": "D3=No 快速退出"
      }
    }
  },
  "swim_lanes": {
    "enabled": "false"
  },
  "legend": {
    "enabled": true,
    "position": "bottom-right"
  },
  "constraints": {
    "must_keep": [
      "決策必有 Yes/No 或等義標籤",
      "子流程為雙框"
    ],
    "avoid": [
      ">15 節點"
    ]
  }
