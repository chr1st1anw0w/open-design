{
  "mcpServers": {
    "puppeteer": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ],
      "env": {
        "NODE_ENV": "production",
        "HEADLESS": "true"
      },
      "enabled": true
    },
    "desktop-commander": {
      "command": "npx",
      "args": [
        "-y",
        "@wonderwhy-er/desktop-commander"
      ],
      "env": {},
      "enabled": true
    },
    "obsidian-git": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-obsidian",
        "/Users/christianwu/Library/Mobile Documents/iCloud~md~obsidian/Documents/Git"
      ],
      "env": {
        "OBSIDIAN_VAULT_PATH": "/Users/christianwu/Library/Mobile Documents/iCloud~md~obsidian/Documents/Git"
      },
      "enabled": true
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest"
      ],
      "env": {},
      "enabled": true
    },
    "notebooklm-mcp": {
      "command": "notebooklm-mcp",
      "args": [],
      "env": {},
      "enabled": true
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {
        "MEMORY_MAX_ENTRIES": "1000",
        "MEMORY_CLEANUP_INTERVAL_MS": "300000",
        "MEMORY_IDLE_TIMEOUT_MS": "1800000",
        "MEMORY_CHUNK_SIZE_BYTES": "20971520",
        "MEMORY_BUFFER_MIN_KB": "512",
        "MEMORY_BUFFER_MAX_MB": "32",
        "NODE_ENV": "production"
      },
      "enabled": true
    },
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-fetch"
      ],
      "env": {},
      "enabled": true
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem"
      ],
      "env": {},
      "enabled": true
    },
    "gitnexus": {
      "command": "npx",
      "args": [
        "-y",
        "gitnexus@latest",
        "mcp"
      ],
      "env": {},
      "enabled": true
    },
    "notion-api": {
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\": \"Bearer ${NOTION_TOKEN}\", \"Notion-Version\": \"2022-06-28\", \"Content-Type\": \"application/json\"}",
        "NOTION_DATABASE_ID": "${NOTION_DATABASE_ID}"
      },
      "enabled": true
    },
    "@21st-dev/magic": {
      "command": "npx",
      "args": [
        "-y",
        "@21st-dev/magic@latest"
      ],
      "env": {
        "API_KEY": "${MAGIC_API_KEY}"
      },
      "enabled": true
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "enabled": true
    },
    "pencil": {
      "command": "/Users/christianwu/.pencil/mcp/antigravity/out/mcp-server-darwin-x64",
      "args": [
        "--app",
        "antigravity"
      ],
      "env": {},
      "enabled": true
    },
    "firecrawl": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}",
        "NODE_ENV": "production",
        "TIMEOUT_MS": "60000",
        "MAX_PAGES": "50"
      },
      "enabled": true
    },
    "figma": {
      "command": "npx",
      "args": [
        "-y",
        "@figma/mcp-server"
      ],
      "env": {
        "FIGMA_API_KEY": "${FIGMA_API_KEY}"
      },
      "enabled": false
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {},
      "enabled": false
    },
    "context7-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {},
      "enabled": true
    },
    "v0": {
      "command": "npx",
      "args": [
        "-y",
        "@v0/mcp"
      ],
      "env": {
        "V0_API_KEY": "${V0_API_KEY}"
      },
      "enabled": false
    },
    "render": {
      "command": "npx",
      "args": [
        "-y",
        "@betterhunt/render-mcp-server"
      ],
      "env": {
        "RENDER_API_KEY": "${RENDER_API_KEY}"
      },
      "enabled": false
    },
    "framer": {
      "url": "https://mcp.unframer.co/sse?id=YOUR_ID&secret=YOUR_SECRET",
      "enabled": false
    },
    "stitch": {
      "command": "npx",
      "args": [
        "-y",
        "stitch-mcp-auto"
      ],
      "env": {
        "GOOGLE_CLOUD_PROJECT": "new-260203"
      },
      "enabled": false
    }
  }
}
